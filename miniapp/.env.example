# Campus Helper - 环境变量配置示例
# 复制此文件为 .env 并填入你的真实密钥

# Supabase 配置
TARO_APP_SUPABASE_URL=你的_supabase_url
TARO_APP_SUPABASE_ANON_KEY=你的_supabase_anon_key

# 高德地图配置
TARO_APP_AMAP_KEY=你的_高德地图_小程序Key
TARO_APP_AMAP_WEB_KEY=你的_高德地图_WebKey
TARO_APP_AMAP_JS_KEY=你的_高德地图_JSAPI_Key
TARO_APP_AMAP_SECURITY_KEY=你的_高德地图_安全密钥

# 地图 Webview 地址（可选）
TARO_APP_MAP_WEBVIEW_URL=
